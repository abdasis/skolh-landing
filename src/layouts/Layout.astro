<style is:global>
	:root {
		--bg: #f5f7ff;
		--surface: #ffffff;
		--ink: #0f1535;
		--ink-2: #4a5278;
		--muted: #8a90b2;
		--primary: #5b6cff;
		--primary-dark: #3d4ed1;
		--accent: #ffb547;
		--accent-2: #ff7a59;
		--mint: #2ed3a6;
		--pink: #ff6b9d;
		--purple: #8b5cf6;
		--border: #e6e9f5;
	}

	.lucide { width: 22px; height: 22px; stroke-width: 2; }

	* { box-sizing: border-box; }

	html, body {
		margin: 0;
		padding: 0;
		font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
		color: var(--ink);
		background: var(--bg);
		-webkit-font-smoothing: antialiased;
		scroll-behavior: smooth;
	}

	a { color: inherit; text-decoration: none; }
	img, svg { display: block; max-width: 100%; }

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
	}

	/* ===== NAVBAR ===== */
	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 72px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		font-weight: 800;
		font-size: 20px;
	}
	.brand-mark {
		width: 36px;
		height: 36px;
		border-radius: 10px;
		background: var(--primary);
		display: grid;
		place-items: center;
		color: #fff;
		font-weight: 800;
	}
	.nav-links {
		display: flex;
		gap: 32px;
		font-weight: 500;
		color: var(--ink-2);
	}
	.nav-links a:hover { color: var(--primary); }
	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: var(--ink);
		color: #fff;
		padding: 10px 18px;
		border-radius: 999px;
		font-weight: 600;
		font-size: 14px;
		transition: transform .2s;
	}
	.nav-cta:hover { transform: translateY(-2px); }
	@media (max-width: 820px) { .nav-links { display: none; } }

	/* ===== HERO ===== */
	.hero {
		padding: 80px 0 100px;
		position: relative;
		overflow: hidden;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1.05fr 1fr;
		gap: 60px;
		align-items: center;
	}
	@media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: #fff;
		border: 1px solid var(--border);
		padding: 8px 16px;
		border-radius: 999px;
		font-size: 13px;
		font-weight: 600;
		color: var(--primary);
	}
	.eyebrow .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--mint); }
	h1.hero-title {
		font-size: clamp(36px, 5vw, 60px);
		line-height: 1.05;
		margin: 22px 0 20px;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.hero-title span { color: var(--primary); }
	.hero-sub {
		font-size: 18px;
		color: var(--ink-2);
		line-height: 1.65;
		max-width: 540px;
	}
	.hero-cta {
		margin-top: 32px;
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 16px 28px;
		border-radius: 14px;
		font-weight: 700;
		font-size: 15px;
		transition: transform .2s, box-shadow .2s;
		cursor: pointer;
		border: none;
	}
	.btn-primary {
		background: var(--primary);
		color: #fff;
	}
	.btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); }
	.btn-ghost {
		background: transparent;
		color: var(--ink);
		border: 1.5px solid var(--ink);
	}
	.btn-ghost:hover { background: var(--ink); color: #fff; }
	.hero-stats {
		margin-top: 48px;
		display: flex;
		gap: 40px;
		flex-wrap: wrap;
	}
	.stat-num { font-size: 28px; font-weight: 800; color: var(--ink); }
	.stat-label { font-size: 13px; color: var(--muted); font-weight: 500; }

	/* Hero blob bg */

	/* ===== SECTIONS ===== */
	section { padding: 100px 0; }
	.section-head { text-align: center; max-width: 680px; margin: 0 auto 60px; }
	.section-tag {
		display: inline-block;
		font-size: 13px;
		font-weight: 700;
		color: var(--primary);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 14px;
	}
	.section-title {
		font-size: clamp(28px, 4vw, 42px);
		font-weight: 800;
		letter-spacing: -0.02em;
		margin: 0 0 16px;
		line-height: 1.15;
	}
	.section-sub {
		color: var(--ink-2);
		font-size: 17px;
		line-height: 1.65;
	}

	/* ===== FEATURES ===== */
	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	@media (max-width: 900px) { .features-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }
	.feature {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 32px 28px;
		transition: transform .25s, border-color .25s;
	}
	.feature:hover { transform: translateY(-4px); border-color: var(--primary); }
	.feature-icon {
		width: 56px;
		height: 56px;
		border-radius: 16px;
		display: grid;
		place-items: center;
		margin-bottom: 20px;
	}
	.feature-icon .lucide { width: 26px; height: 26px; }
	.f-1 { background: rgba(91, 108, 255, 0.12); color: var(--primary); }
	.f-2 { background: rgba(46, 211, 166, 0.14); color: var(--mint); }
	.f-3 { background: rgba(255, 122, 89, 0.14); color: var(--accent-2); }
	.f-4 { background: rgba(139, 92, 246, 0.14); color: var(--purple); }
	.f-5 { background: rgba(255, 181, 71, 0.18); color: #d68a00; }
	.f-6 { background: rgba(255, 107, 157, 0.14); color: var(--pink); }
	.feature h3 { font-size: 19px; margin: 0 0 10px; font-weight: 700; }
	.feature p { color: var(--ink-2); line-height: 1.6; margin: 0; font-size: 15px; }

	/* ===== CLIENT (LOGO STRIP) ===== */
	.clients {
		background: #fff;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}
	.clients-head { text-align: center; margin-bottom: 40px; }
	.clients-head p { color: var(--muted); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; font-size: 13px; margin: 0; }
	.client-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 20px;
		align-items: center;
	}
	@media (max-width: 900px) { .client-grid { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 500px) { .client-grid { grid-template-columns: repeat(2, 1fr); } }
	.client-card {
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 22px 16px;
		text-align: center;
		font-weight: 700;
		color: var(--ink-2);
		font-size: 14px;
		transition: transform .2s, color .2s;
	}
	.client-card:hover { transform: translateY(-4px); color: var(--primary); }
	.client-card .logo {
		width: 44px;
		height: 44px;
		margin: 0 auto 10px;
		border-radius: 12px;
		display: grid;
		place-items: center;
		font-size: 18px;
		font-weight: 800;
		color: #fff;
	}

	/* ===== HOW IT WORKS ===== */
	.steps {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}
	@media (max-width: 900px) { .steps { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 500px) { .steps { grid-template-columns: 1fr; } }
	.step {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 32px 24px;
		position: relative;
	}
	.step-num {
		position: absolute;
		top: -16px; left: 24px;
		background: var(--primary);
		color: #fff;
		width: 38px; height: 38px;
		border-radius: 12px;
		display: grid;
		place-items: center;
		font-weight: 800;
	}
	.step h4 { margin: 14px 0 8px; font-size: 18px; }
	.step p { margin: 0; color: var(--ink-2); font-size: 14px; line-height: 1.6; }

	/* ===== TESTIMONI ===== */
	.testimonials { background: linear-gradient(180deg, #fff 0%, var(--bg) 100%); }
	.testi-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	@media (max-width: 900px) { .testi-grid { grid-template-columns: 1fr; } }
	.testi {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 22px;
		padding: 32px 28px;
		position: relative;
	}
	.testi .quote {
		font-size: 60px;
		line-height: 1;
		color: var(--primary);
		opacity: 0.18;
		font-family: Georgia, serif;
		position: absolute;
		top: 18px; right: 24px;
	}
	.testi p {
		color: var(--ink-2);
		font-size: 15px;
		line-height: 1.7;
		margin: 0 0 24px;
	}
	.testi-person { display: flex; align-items: center; gap: 14px; }
	.avatar {
		width: 48px; height: 48px;
		border-radius: 50%;
		display: grid;
		place-items: center;
		color: #fff;
		font-weight: 700;
	}
	.testi-name { font-weight: 700; font-size: 15px; }
	.testi-role { font-size: 13px; color: var(--muted); }
	.stars { color: var(--accent); margin-bottom: 16px; letter-spacing: 2px; font-size: 16px; }

	/* ===== CTA ===== */
	.cta-band {
		background: var(--ink);
		border-radius: 28px;
		padding: 60px 50px;
		color: #fff;
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 40px;
		align-items: center;
		position: relative;
		overflow: hidden;
	}
	@media (max-width: 800px) { .cta-band { grid-template-columns: 1fr; padding: 40px 30px; } }
	.cta-band h2 { font-size: clamp(26px, 3vw, 36px); margin: 0 0 14px; font-weight: 800; }
	.cta-band p { margin: 0 0 24px; opacity: 0.9; font-size: 16px; line-height: 1.6; }
	.cta-band .btn-primary {
		background: #fff;
		color: var(--ink);
	}
	.cta-band .btn-primary:hover { background: var(--accent); color: var(--ink); }

	/* ===== FOOTER ===== */
	footer {
		background: var(--ink);
		color: #c4c8e0;
		padding: 70px 0 30px;
	}
	.foot-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: 50px;
		margin-bottom: 50px;
	}
	@media (max-width: 800px) { .foot-grid { grid-template-columns: 1fr 1fr; } }
	.foot-brand { color: #fff; }
	.foot-brand p { color: #8a90b2; line-height: 1.6; margin-top: 14px; max-width: 320px; font-size: 14px; }
	.foot-col h5 { color: #fff; font-size: 14px; margin: 0 0 18px; text-transform: uppercase; letter-spacing: 0.08em; }
	.foot-col a { display: block; padding: 6px 0; color: #8a90b2; font-size: 14px; }
	.foot-col a:hover { color: #fff; }
	.foot-bot {
		border-top: 1px solid #1f2547;
		padding-top: 24px;
		text-align: center;
		font-size: 13px;
		color: #6c7398;
	}

	/* Isometric SVG hover float */
	.iso-wrap { position: relative; }
	@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
	.iso-float { animation: float 6s ease-in-out infinite; }
</style>
