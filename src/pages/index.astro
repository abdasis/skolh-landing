---

<Layout>
	<Navbar activePage="home" />

	<section class="hero">
		<div class="container hero-grid">
			<div>
				<span class="eyebrow"><span class="dot"></span> Platform #1 Manajemen Sekolah</span>
				<h1 class="hero-title">Kelola Sekolah Anda dengan <span>Lebih Modern</span></h1>
				<p class="hero-sub">
					Skolh adalah platform all-in-one untuk profil sekolah, penerimaan siswa baru online, manajemen siswa, alumni, dan komunikasi publik — semua dalam satu dashboard yang mudah.
				</p>
				<div class="hero-cta">
					<MulaiGratisButton href="#cta" client:load />
					<a href="#fitur" class="btn btn-ghost">Lihat Fitur</a>
				</div>
				<div class="hero-stats">
					<div>
						<div class="stat-num">100+</div>
						<div class="stat-label">Sekolah Terdaftar</div>
					</div>
					<div>
						<div class="stat-num">15K+</div>
						<div class="stat-label">Siswa Aktif</div>
					</div>
					<div>
						<div class="stat-num">99.9%</div>
						<div class="stat-label">Uptime</div>
					</div>
				</div>
			</div>

			<div class="iso-wrap iso-float">
				<svg viewBox="0 0 500 460" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<linearGradient id="g1" x1="0" x2="1" y1="0" y2="1">
							<stop offset="0" stop-color="#5b6cff"/>
							<stop offset="1" stop-color="#8b5cf6"/>
						</linearGradient>
						<linearGradient id="g2" x1="0" x2="0" y1="0" y2="1">
							<stop offset="0" stop-color="#ffb547"/>
							<stop offset="1" stop-color="#ff7a59"/>
						</linearGradient>
					</defs>
					<ellipse cx="250" cy="410" rx="200" ry="20" fill="#0f1535" opacity="0.08"/>

					<g transform="translate(60,80)">
						<polygon points="0,40 140,0 230,45 90,85" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,40 0,140 90,185 90,85" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="90,85 230,45 230,145 90,185" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,55 35,48 35,28 20,35" fill="#2ed3a6"/>
						<polygon points="55,45 70,38 70,8 55,15" fill="#5b6cff"/>
						<polygon points="90,35 105,28 105,-12 90,-5" fill="#ffb547"/>
						<polygon points="125,25 140,18 140,-2 125,5" fill="#ff7a59"/>
					</g>

					<g transform="translate(180,150)">
						<polygon points="0,80 110,30 220,80 110,130" fill="url(#g1)" opacity="0.95"/>
						<polygon points="0,80 0,180 110,230 110,130" fill="#3d4ed1"/>
						<polygon points="110,130 220,80 220,180 110,230" fill="#5b6cff"/>
						<polygon points="95,170 125,155 125,200 95,215" fill="#0f1535" opacity="0.3"/>
						<polygon points="20,130 45,118 45,138 20,150" fill="#fff" opacity="0.85"/>
						<polygon points="60,110 85,98 85,118 60,130" fill="#fff" opacity="0.85"/>
						<polygon points="140,148 165,135 165,155 140,168" fill="#fff" opacity="0.85"/>
						<polygon points="180,128 205,115 205,135 180,148" fill="#fff" opacity="0.85"/>
						<line x1="110" y1="30" x2="110" y2="-30" stroke="#0f1535" stroke-width="3"/>
						<polygon points="110,-30 145,-22 110,-12" fill="url(#g2)"/>
					</g>

					<g transform="translate(280,250)">
						<polygon points="0,40 130,-10 200,30 70,80" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,40 0,110 70,150 70,80" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="70,80 200,30 200,100 70,150" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,40 95,12 95,22 20,50" fill="#5b6cff" opacity="0.6"/>
						<polygon points="20,55 80,32 80,42 20,65" fill="#2ed3a6" opacity="0.6"/>
						<polygon points="20,70 90,43 90,53 20,80" fill="#ffb547" opacity="0.6"/>
					</g>

					<g transform="translate(40,260)">
						<polygon points="0,20 40,5 60,20 20,35" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,20 0,45 20,60 20,35" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,35 60,20 60,45 20,60" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<circle cx="30" cy="30" r="6" fill="#2ed3a6"/>
					</g>

					<g transform="translate(400,140)">
						<polygon points="0,20 40,5 60,20 20,35" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,20 0,45 20,60 20,35" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,35 60,20 60,45 20,60" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
