	</section>

	<section class="clients" id="klien">
		<div class="container">
			<div class="clients-head">
				<p>Dipercaya oleh sekolah di seluruh Indonesia</p>
			</div>
			<div class="client-grid">
				{clients.map((c) => (
					<div class="client-card">
						<div class="logo" style={`background: ${c.color}`}>{c.initials}</div>
						{c.name}
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="fitur">
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Fitur Lengkap</div>
				<h2 class="section-title">Semua yang Sekolah Anda Butuhkan</h2>
				<p class="section-sub">Dari profil sekolah sampai penerimaan siswa baru online — Skolh menyediakan modul yang siap pakai dan mudah dikustomisasi.</p>
			</div>
			<FiturBento client:load />
		</div>
	</section>

	<section id="cara-kerja" class="how-section">
		<div class="how-bg-grid"></div>
		<div class="how-bg-glow"></div>
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Cara Kerja</div>
				<h2 class="section-title">Mulai dalam 4 Langkah Mudah</h2>
				<p class="section-sub">Tidak perlu setup rumit. Sekolah Anda bisa online dalam waktu singkat.</p>
			</div>

			<div class="how-steps">
				<div class="how-beam"></div>
				{steps.map((s, i) => (
					<div class="how-step" style={`--delay:${i * 0.15}s; --grad:${s.gradient}`}>
						<div class="how-step-border">
							<div class="how-step-inner">
								<div class="how-step-head">
									<div class="how-icon" style={`background:${s.gradient}`}>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
									</div>
									<div class="how-num">0{i + 1}</div>
								</div>
								<h4>{s.title}</h4>
								<p>{s.desc}</p>
								<div class="how-shine"></div>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="testimonials" id="testimoni">
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Testimoni</div>
				<h2 class="section-title">Apa Kata Mereka tentang Skolh</h2>
				<p class="section-sub">Cerita nyata dari sekolah-sekolah yang sudah mempercayakan manajemen mereka pada Skolh.</p>
			</div>
		</div>
		<div class="marquee-wrapper">
			<div class="marquee-fade-left"></div>
			<div class="marquee-fade-right"></div>

			<div class="marquee-track">
				<div class="marquee-row marquee-ltr">
					{[...testimonialsRow1, ...testimonialsRow1].map((t) => (
						<div class="testi-card">
							<div class="testi-card-top">
								<div class="stars">★★★★★</div>
								<div class="quote-mark">"</div>
							</div>
							<p>{t.text}</p>
							<div class="testi-person">
								<div class="avatar" style={`background: ${t.color}`}>{t.initials}</div>
								<div>
									<div class="testi-name">{t.name}</div>
									<div class="testi-role">{t.role}</div>
								</div>
							</div>
						</div>
					))}
				</div>
				<div class="marquee-row marquee-rtl">
					{[...testimonialsRow2, ...testimonialsRow2].map((t) => (
						<div class="testi-card">
							<div class="testi-card-top">
								<div class="stars">★★★★★</div>
								<div class="quote-mark">"</div>
							</div>
							<p>{t.text}</p>
							<div class="testi-person">
								<div class="avatar" style={`background: ${t.color}`}>{t.initials}</div>
								<div>
									<div class="testi-name">{t.name}</div>
									<div class="testi-role">{t.role}</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="cta">
		<div class="container">
			<div class="cta-band">
				<div>
					<h2>Siap Membawa Sekolah Anda ke Era Digital?</h2>
					<p>Bergabung dengan 100+ sekolah yang sudah merasakan kemudahan mengelola operasional dan komunikasi publik dengan Skolh.</p>
					<MulaiGratisButton client:load />
				</div>
				<div style="text-align:center;">
					<svg style="width:120px;height:120px;color:#fff;opacity:0.85" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.rocket}></svg>
				</div>
			</div>
		</div>
	</section>

	<Footer />
</Layout>

<style is:global>
	html, body { overflow-x: hidden; max-width: 100%; }

	/* ===== CARA KERJA — CLEAN WHITE ===== */
	.how-section {
		position: relative;
		background: #ffffff;
		border-top: 1px solid #eceef5;
		border-bottom: 1px solid #eceef5;
		overflow: hidden;
		color: #0a0b1e;
	}
	.how-section .section-tag {
		background: #f5f6fb;
		color: #5b6cff;
		border: 1px solid #e6e8f2;
	}
	.how-section .section-title { color: #0a0b1e; }
	.how-section .section-sub { color: #5c6278; }

	.how-bg-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, rgba(10, 11, 30, 0.04) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(10, 11, 30, 0.04) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, #000 40%, transparent 100%);
		-webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, #000 40%, transparent 100%);
		pointer-events: none;
	}
	.how-bg-glow {
		display: none;
	}

	.how-steps {
		position: relative;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
		margin-top: 20px;
	}
	@media (max-width: 900px) { .how-steps { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 560px) { .how-steps { grid-template-columns: 1fr; } }

	.how-beam {
		position: absolute;
		top: 48px;
		left: 8%;
		right: 8%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #eceef5 20%, #eceef5 80%, transparent);
		z-index: 0;
	}
	.how-beam::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, transparent, rgba(91, 108, 255, 0.5), transparent);
		background-size: 200px 100%;
		background-repeat: no-repeat;
		animation: how-beam-slide 3s linear infinite;
	}
	@keyframes how-beam-slide {
		0% { background-position: -200px 0; }
		100% { background-position: calc(100% + 200px) 0; }
	}
	@media (max-width: 900px) { .how-beam { display: none; } }

	.how-step {
		position: relative;
		z-index: 1;
		opacity: 0;
		transform: translateY(20px);
		animation: how-step-in 0.6s ease-out forwards;
		animation-delay: var(--delay);
	}
	@keyframes how-step-in {
		to { opacity: 1; transform: translateY(0); }
	}

	.how-step-border {
		position: relative;
		border-radius: 20px;
		padding: 1px;
		background: #eceef5;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		height: 100%;
	}
	.how-step:hover .how-step-border { box-shadow: 0 12px 32px rgba(10, 11, 30, 0.08); }
	.how-step-border::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 20px;
		padding: 1px;
		background: var(--grad);
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0;
