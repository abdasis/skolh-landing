---
import Layout from '../layouts/Layout.astro';

// Lucide icon paths (https://lucide.dev) — inline SVG, no install
const ICONS = {
	graduation: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>',
	calendar: '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
	users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
	building: '<rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"/>',
	pen: '<path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/>',
	palette: '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2"/>',
	arrowRight: '<path d="M5 12h14M12 5l7 7-7 7"/>',
	rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
};

const features = [
	{ icon: ICONS.graduation, cls: 'f-1', bc: 'bc-1', span: 'bento-span-2', title: 'SPMB Online', desc: 'Sistem Penerimaan Murid Baru lengkap dengan custom field, status tracking, dan ekspor PDF.' },
	{ icon: ICONS.calendar, cls: 'f-2', bc: 'bc-2', span: '', title: 'Agenda & Pengumuman', desc: 'Kelola agenda sekolah dan pengumuman dengan lampiran file untuk diakses publik.' },
	{ icon: ICONS.users, cls: 'f-3', bc: 'bc-3', span: '', title: 'Manajemen Siswa & Alumni', desc: 'Data siswa aktif dan profil alumni terorganisir dengan baik dalam satu sistem.' },
	{ icon: ICONS.building, cls: 'f-4', bc: 'bc-4', span: 'bento-span-2', title: 'Profil Sekolah', desc: 'Visi misi, fasilitas, ekstrakurikuler, prestasi, dan struktur organisasi yang lengkap.' },
	{ icon: ICONS.pen, cls: 'f-5', bc: 'bc-5', span: '', title: 'CMS Artikel & Galeri', desc: 'Publikasikan artikel dengan editor kaya dan kelola galeri foto kegiatan sekolah.' },
	{ icon: ICONS.palette, cls: 'f-6', bc: 'bc-6', span: '', title: 'Multi Tema', desc: 'Pilih tema yang sesuai identitas sekolah Anda dengan kustomisasi warna dan layout.' },
];

const clients = [
	{ name: 'SMA Negeri 1', initials: 'S1', color: '#5b6cff' },
	{ name: 'SMK Mandiri', initials: 'SM', color: '#2ed3a6' },
	{ name: 'MTs Al-Hikmah', initials: 'AH', color: '#ff7a59' },
	{ name: 'SD Cendekia', initials: 'SC', color: '#8b5cf6' },
	{ name: 'SMP Harapan', initials: 'SH', color: '#ffb547' },
	{ name: 'MA Nurul Ilmi', initials: 'NI', color: '#ff6b9d' },
];

const steps = [
	{ title: 'Daftar Akun', desc: 'Buat akun admin sekolah dalam hitungan menit, gratis tanpa kartu kredit.' },
	{ title: 'Atur Profil', desc: 'Lengkapi profil sekolah, visi misi, fasilitas, dan struktur organisasi.' },
	{ title: 'Aktifkan Modul', desc: 'Pilih dan aktifkan modul yang dibutuhkan: SPMB, agenda, artikel, dll.' },
	{ title: 'Go Live', desc: 'Website sekolah siap online dan menerima pendaftaran siswa baru.' },
];

const testimonials = [
	{
		name: 'Bpk. Ahmad Hidayat',
		role: 'Kepala SMA Negeri 1',
		color: '#5b6cff',
		initials: 'AH',
		text: 'Skolh benar-benar membantu sekolah kami digitalisasi. Proses PPDB yang dulunya manual sekarang jadi jauh lebih efisien dan transparan untuk wali murid.',
	},
	{
		name: 'Ibu Siti Rahmawati',
		role: 'Admin SMK Mandiri',
		color: '#2ed3a6',
		initials: 'SR',
		text: 'Antarmuka admin sangat mudah dipakai. Saya tidak perlu jadi ahli IT untuk mengelola pengumuman, agenda, dan data siswa setiap hari.',
	},
	{
		name: 'Bpk. Bambang Prasetyo',
		role: 'Wakasek MTs Al-Hikmah',
		color: '#ff7a59',
		initials: 'BP',
		text: 'Modul alumni dan testimoni jadi favorit kami. Sekolah jadi punya wadah untuk menjaga koneksi dengan lulusan yang sudah tersebar di mana-mana.',
	},
];
---

<Layout>
	<header class="nav">
		<div class="container nav-inner">
			<a href="#" class="brand">
				<span class="brand-mark">S</span>
				Skolh
			</a>
			<nav class="nav-links">
				<a href="#fitur">Fitur</a>
				<a href="#klien">Klien</a>
				<a href="#cara-kerja">Cara Kerja</a>
				<a href="#testimoni">Testimoni</a>
			</nav>
			<a href="#cta" class="nav-cta">Mulai Gratis <svg class="lucide" style="width:16px;height:16px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.arrowRight}></svg></a>
		</div>
	</header>

	<section class="hero">
		<div class="container hero-grid">
			<div>
				<span class="eyebrow"><span class="dot"></span> Platform #1 Manajemen Sekolah</span>
				<h1 class="hero-title">Kelola Sekolah Anda dengan <span>Lebih Modern</span></h1>
				<p class="hero-sub">
					Skolh adalah platform all-in-one untuk profil sekolah, penerimaan siswa baru online, manajemen siswa, alumni, dan komunikasi publik — semua dalam satu dashboard yang mudah.
				</p>
				<div class="hero-cta">
					<a href="#cta" class="btn btn-primary">Coba Gratis Sekarang <svg class="lucide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.arrowRight}></svg></a>
					<a href="#fitur" class="btn btn-ghost">Lihat Fitur</a>
				</div>
				<div class="hero-stats">
					<div>
						<div class="stat-num">100+</div>
						<div class="stat-label">Sekolah Terdaftar</div>
					</div>
					<div>
						<div class="stat-num">15K+</div>
						<div class="stat-label">Siswa Aktif</div>
					</div>
					<div>
						<div class="stat-num">99.9%</div>
						<div class="stat-label">Uptime</div>
					</div>
				</div>
			</div>

			<div class="iso-wrap iso-float">
				<svg viewBox="0 0 500 460" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<linearGradient id="g1" x1="0" x2="1" y1="0" y2="1">
							<stop offset="0" stop-color="#5b6cff"/>
							<stop offset="1" stop-color="#8b5cf6"/>
						</linearGradient>
						<linearGradient id="g2" x1="0" x2="0" y1="0" y2="1">
							<stop offset="0" stop-color="#ffb547"/>
							<stop offset="1" stop-color="#ff7a59"/>
						</linearGradient>
					</defs>
					<ellipse cx="250" cy="410" rx="200" ry="20" fill="#0f1535" opacity="0.08"/>

					<g transform="translate(60,80)">
						<polygon points="0,40 140,0 230,45 90,85" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,40 0,140 90,185 90,85" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="90,85 230,45 230,145 90,185" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,55 35,48 35,28 20,35" fill="#2ed3a6"/>
						<polygon points="55,45 70,38 70,8 55,15" fill="#5b6cff"/>
						<polygon points="90,35 105,28 105,-12 90,-5" fill="#ffb547"/>
						<polygon points="125,25 140,18 140,-2 125,5" fill="#ff7a59"/>
					</g>

					<g transform="translate(180,150)">
						<polygon points="0,80 110,30 220,80 110,130" fill="url(#g1)" opacity="0.95"/>
						<polygon points="0,80 0,180 110,230 110,130" fill="#3d4ed1"/>
						<polygon points="110,130 220,80 220,180 110,230" fill="#5b6cff"/>
						<polygon points="95,170 125,155 125,200 95,215" fill="#0f1535" opacity="0.3"/>
						<polygon points="20,130 45,118 45,138 20,150" fill="#fff" opacity="0.85"/>
						<polygon points="60,110 85,98 85,118 60,130" fill="#fff" opacity="0.85"/>
						<polygon points="140,148 165,135 165,155 140,168" fill="#fff" opacity="0.85"/>
						<polygon points="180,128 205,115 205,135 180,148" fill="#fff" opacity="0.85"/>
						<line x1="110" y1="30" x2="110" y2="-30" stroke="#0f1535" stroke-width="3"/>
						<polygon points="110,-30 145,-22 110,-12" fill="url(#g2)"/>
					</g>

					<g transform="translate(280,250)">
						<polygon points="0,40 130,-10 200,30 70,80" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,40 0,110 70,150 70,80" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="70,80 200,30 200,100 70,150" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,40 95,12 95,22 20,50" fill="#5b6cff" opacity="0.6"/>
						<polygon points="20,55 80,32 80,42 20,65" fill="#2ed3a6" opacity="0.6"/>
						<polygon points="20,70 90,43 90,53 20,80" fill="#ffb547" opacity="0.6"/>
					</g>

					<g transform="translate(40,260)">
						<polygon points="0,20 40,5 60,20 20,35" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,20 0,45 20,60 20,35" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,35 60,20 60,45 20,60" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<circle cx="30" cy="30" r="6" fill="#2ed3a6"/>
					</g>

					<g transform="translate(400,140)">
						<polygon points="0,20 40,5 60,20 20,35" fill="#fff" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="0,20 0,45 20,60 20,35" fill="#eef0fb" stroke="#e6e9f5" stroke-width="2"/>
						<polygon points="20,35 60,20 60,45 20,60" fill="#dde1f5" stroke="#e6e9f5" stroke-width="2"/>
						<circle cx="30" cy="30" r="6" fill="#ff7a59"/>
					</g>
				</svg>
			</div>
		</div>
	</section>

	<section class="clients" id="klien">
		<div class="container">
			<div class="clients-head">
				<p>Dipercaya oleh sekolah di seluruh Indonesia</p>
			</div>
			<div class="client-grid">
				{clients.map((c) => (
					<div class="client-card">
						<div class="logo" style={`background: ${c.color}`}>{c.initials}</div>
						{c.name}
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="fitur">
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Fitur Lengkap</div>
				<h2 class="section-title">Semua yang Sekolah Anda Butuhkan</h2>
				<p class="section-sub">Dari profil sekolah sampai penerimaan siswa baru online — Skolh menyediakan modul yang siap pakai dan mudah dikustomisasi.</p>
			</div>
			<div class="bento-grid">
				{features.map((f) => (
					<div class={`bento-card ${f.bc} ${f.span}`}>
						<div class="bento-bg">
							<div class="bento-blob"></div>
						</div>
						<div class="bento-content">
							<div class={`bento-icon ${f.cls}`}>
								<svg class="lucide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}></svg>
							</div>
							<h3>{f.title}</h3>
							<p>{f.desc}</p>
						</div>
						<div class="bento-cta">
							<a href="#cta" class="bento-cta-link">
								Pelajari lebih lanjut
								<svg class="lucide" style="width:14px;height:14px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.arrowRight}></svg>
							</a>
						</div>
						<div class="bento-overlay"></div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="cara-kerja" style="background:#fff;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Cara Kerja</div>
				<h2 class="section-title">Mulai dalam 4 Langkah Mudah</h2>
				<p class="section-sub">Tidak perlu setup rumit. Sekolah Anda bisa online dalam waktu singkat.</p>
			</div>
			<div class="steps">
				{steps.map((s, i) => (
					<div class="step">
						<div class="step-num">{i + 1}</div>
						<h4>{s.title}</h4>
						<p>{s.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="testimonials" id="testimoni">
		<div class="container">
			<div class="section-head">
				<div class="section-tag">Testimoni</div>
				<h2 class="section-title">Apa Kata Mereka tentang Skolh</h2>
				<p class="section-sub">Cerita nyata dari sekolah-sekolah yang sudah mempercayakan manajemen mereka pada Skolh.</p>
			</div>
			<div class="testi-grid">
				{testimonials.map((t) => (
					<div class="testi">
						<div class="quote">”</div>
						<div class="stars">★★★★★</div>
						<p>{t.text}</p>
						<div class="testi-person">
							<div class="avatar" style={`background: ${t.color}`}>{t.initials}</div>
							<div>
								<div class="testi-name">{t.name}</div>
								<div class="testi-role">{t.role}</div>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="cta">
		<div class="container">
			<div class="cta-band">
				<div>
					<h2>Siap Membawa Sekolah Anda ke Era Digital?</h2>
					<p>Bergabung dengan 100+ sekolah yang sudah merasakan kemudahan mengelola operasional dan komunikasi publik dengan Skolh.</p>
					<a href="#" class="btn btn-primary">Mulai Gratis <svg class="lucide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.arrowRight}></svg></a>
				</div>
				<div style="text-align:center;">
					<svg style="width:120px;height:120px;color:#fff;opacity:0.85" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.rocket}></svg>
				</div>
			</div>
		</div>
	</section>

	<footer>
		<div class="container">
			<div class="foot-grid">
				<div class="foot-brand">
					<div class="brand" style="color:#fff">
						<span class="brand-mark">S</span> Skolh
					</div>
					<p>Platform manajemen sekolah modern untuk profil, penerimaan siswa baru, dan komunikasi publik dalam satu dashboard.</p>
				</div>
				<div class="foot-col">
					<h5>Produk</h5>
					<a href="#fitur">Fitur</a>
					<a href="#cara-kerja">Cara Kerja</a>
					<a href="#testimoni">Testimoni</a>
				</div>
				<div class="foot-col">
					<h5>Perusahaan</h5>
					<a href="#">Tentang</a>
					<a href="#">Blog</a>
					<a href="#">Kontak</a>
				</div>
				<div class="foot-col">
					<h5>Hukum</h5>
					<a href="#">Privasi</a>
					<a href="#">Syarat</a>
				</div>
			</div>
			<div class="foot-bot">© {new Date().getFullYear()} Skolh. Semua hak dilindungi.</div>
		</div>
	</footer>
</Layout>
</content>
